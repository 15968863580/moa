# kaka_moa Configuration
# 复制此文件为 .env 并填入实际的 API Key

# OpenAI API Key
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic API Key
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# kaka_moa API Key (客户端访问本服务使用的 Key)
MOA_API_KEY=your-moa-service-api-key-here

# 其他 LLM 提供商的 API Key（按需添加）
# DEEPSEEK_API_KEY=your-deepseek-api-key-here
# LOCAL_MODEL_BASE_URL=http://localhost:11434/v1

# OneAPI（moa-config.yaml 中 reference/aggregator 使用）
ONEAPI_API_KEY=your-oneapi-api-key-here
ONEAPI_BASE_URL=http://your-oneapi-host/v1

# 内置工具 builtin__web_search
WEB_SEARCH_API_BASE_URL=         # 兼容搜索后端，GET ?q=&num=；如 https://api.tavily.com/search 或自建
WEB_SEARCH_API_KEY=              # 若搜索后端需鉴权，会以 Bearer 发送

# 内置工具 builtin__exec / builtin__read_file 的工作目录与超时
EXEC_WORK_DIR=                   # 不填则不限制工作目录
EXEC_TIMEOUT=30

# MCP Server（mcp_servers.github 示例使用）
MCP_GITHUB_URL=                  # 例如 http://localhost:3000/mcp
